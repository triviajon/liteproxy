# AWS region
DEFAULT_AWS_REGION="us-east-1"

# Proxy authentication token (generated randomly if empty)
DEFAULT_PROXY_AUTH_TOKEN=""

# Processor port
DEFAULT_PROCESSOR_PORT="8080"

# VPC CIDR block
DEFAULT_VPC_CIDR="10.0.0.0/16"

# EC2 instance type
DEFAULT_INSTANCE_TYPE="t4g.micro"

# AMI ID
DEFAULT_AMI_ID="ami-04aa82396fe417f2f"

# GHCR Container Image path
DEFAULT_CONTAINER_IMAGE="ghcr.io/triviajon/liteproxy-processor:latest"